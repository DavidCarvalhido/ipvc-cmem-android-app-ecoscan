<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- ═══════════════════════════════════════
         CAMADA 1 — Preview da câmara (fundo)
         ═══════════════════════════════════════ -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:scaleType="fillCenter" />

    <!-- ═══════════════════════════════════════
         CAMADA 2 — Overlay de análise (Canvas)
         Desenhado pelo ScanOverlayView no código
         ═══════════════════════════════════════ -->
    <com.android.daviddev.ecoscancmem.ui.ScanOverlayView
        android:id="@+id/scanOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toTopOf="@id/bottomSheet"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ═══════════════════════════════════════
         CAMADA 3 — Barra superior
         ═══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_btn_overlay"
            android:contentDescription="@string/back"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/app_name"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnInfo"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_btn_overlay"
            android:contentDescription="@string/info"
            android:padding="8dp"
            android:src="@drawable/ic_info" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════
         CAMADA 4 — Aviso de luz insuficiente
         (visibilidade controlada pelo sensor)
         ═══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/lightWarning"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_warning_pill"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:contentDescription=""
            android:src="@drawable/ic_light_off" />

        <TextView
            android:id="@+id/tvLightWarning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:lineSpacingMultiplier="1.3"
            android:text="@string/warning_low_light"
            android:textColor="@color/white"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════
         CAMADA 5 — Dica central (hint)
         ═══════════════════════════════════════ -->
    <TextView
        android:id="@+id/tvHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_hint_pill"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp"
        android:text="@string/scan_hint"
        android:textColor="#CCffffff"
        android:textSize="12sp"
        app:layout_constraintBottom_toTopOf="@id/analysisBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ═══════════════════════════════════════
         CAMADA 6 — Barra de estado de análise
         ═══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/analysisBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_analysis_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomSheet"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ProgressBar
            android:id="@+id/analysisProgress"
            style="@style/Widget.AppCompat.ProgressBar"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:indeterminateTint="@color/green_primary" />

        <TextView
            android:id="@+id/tvAnalysisStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="@string/analysis_running"
            android:textColor="#AAFFFFFF"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════
         CAMADA 7 — Bottom sheet com controlos
         ═══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottomSheet"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/cam_bottom_bg"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Chips de dados dos sensores -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal"
            android:weightSum="3">

            <!-- Chip: Luz -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_sensor_chip"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sensor_light"
                    android:textColor="@color/sensor_label"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvLuxValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="— lux"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Chip: Estabilidade -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="3dp"
                android:layout_weight="1"
                android:background="@drawable/bg_sensor_chip"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sensor_stability"
                    android:textColor="@color/sensor_label"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvStabilityValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="—"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Chip: Modo ativo -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_sensor_chip"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sensor_mode"
                    android:textColor="@color/sensor_label"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvModeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="—"
                    android:textColor="@color/green_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- Linha de controlos principais -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Botão torchlight -->
            <ImageButton
                android:id="@+id/btnTorch"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_ctrl_btn"
                android:contentDescription="@string/torch"
                android:padding="10dp"
                android:src="@drawable/ic_torch" />

            <!-- Tabs de modo -->
            <LinearLayout
                android:id="@+id/modeTabs"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_mode_tabs"
                android:orientation="horizontal"
                android:padding="3dp">

                <TextView
                    android:id="@+id/tabObject"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tab_active"
                    android:gravity="center"
                    android:text="@string/mode_object"
                    android:textColor="@color/white"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tabLabel"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/mode_label"
                    android:textColor="@color/sensor_label"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- Botão captura -->
            <FrameLayout
                android:id="@+id/btnCapture"
                android:layout_width="64dp"
                android:layout_height="64dp">

                <View
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_capture_outer" />

                <View
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_capture_inner" />

            </FrameLayout>

            <!-- Botão histórico -->
            <ImageButton
                android:id="@+id/btnHistory"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_ctrl_btn"
                android:contentDescription="@string/history"
                android:padding="10dp"
                android:src="@drawable/ic_history" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>