<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/green_primary"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@drawable/bg_btn_overlay"
            android:contentDescription="@string/back"
            android:padding="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/how_title"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center" />

        <View
            android:layout_width="32dp"
            android:layout_height="32dp" />

    </LinearLayout>

    <!-- Subtítulo do hero -->
    <LinearLayout
        android:id="@+id/heroSub"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/green_primary"
        android:paddingHorizontal="20dp"
        android:paddingBottom="20dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/how_subtitle"
            android:textSize="13sp"
            android:textColor="#CCffffff"
            android:lineSpacingMultiplier="1.5" />

    </LinearLayout>

    <!-- Scroll principal -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/heroSub"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <!-- SECÇÃO 1 - Como usar a app -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/how_section_steps"
                style="@style/SectionLabel" />

            <include
                android:id="@+id/step1"
                layout="@layout/item_how_step"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <View
                android:layout_width="2dp"
                android:layout_height="12dp"
                android:layout_marginStart="13dp"
                android:layout_marginBottom="4dp"
                android:background="@color/divider" />

            <include
                android:id="@+id/step2"
                layout="@layout/item_how_step"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <View
                android:layout_width="2dp"
                android:layout_height="12dp"
                android:layout_marginStart="13dp"
                android:layout_marginBottom="4dp"
                android:background="@color/divider" />

            <include
                android:id="@+id/step3"
                layout="@layout/item_how_step"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <View
                android:layout_width="2dp"
                android:layout_height="12dp"
                android:layout_marginStart="13dp"
                android:layout_marginBottom="4dp"
                android:background="@color/divider" />

            <include
                android:id="@+id/step4"
                layout="@layout/item_how_step"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- SECÇÃO 2 - Sensores -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="@color/divider"
                android:layout_marginVertical="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/how_section_sensors"
                style="@style/SectionLabel" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Sensor luz -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_impact_card"
                    android:padding="10dp"
                    android:layout_marginEnd="6dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_light_off"
                        android:background="@drawable/bg_feat_teal"
                        android:padding="6dp"
                        android:layout_marginBottom="6dp"
                        android:contentDescription="" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sensor_light_name"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="@string/sensor_light_desc"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>

                <!-- Sensor acelerómetro -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_impact_card"
                    android:padding="10dp"
                    android:layout_marginStart="6dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_accelerometer"
                        android:background="@drawable/bg_feat_blue"
                        android:padding="6dp"
                        android:layout_marginBottom="6dp"
                        android:contentDescription="" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sensor_accel_name"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="@string/sensor_accel_desc"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>

            </LinearLayout>

            <!-- SECÇÃO 3 - Códigos de reciclagem -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="@color/divider"
                android:layout_marginVertical="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/how_section_codes"
                style="@style/SectionLabel" />

            <!-- Cards de código - preenchidos pelo Fragment -->
            <LinearLayout
                android:id="@+id/codesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- BANNER de dica final -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="@color/divider"
                android:layout_marginVertical="20dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_green"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/how_tip_title"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_800" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/how_tip_text"
                    android:textSize="12sp"
                    android:textColor="@color/green_700"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>